rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /submissions/{docId} {
      allow create: if true;
      allow read: if request.auth != null || resource.data.formType == 'enrollment';
      allow update, delete: if request.auth != null;
    }
    match /programs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{docId} {
      // Public can only see published posts; admins see drafts too.
      allow read: if (resource == null || resource.data.status == 'published') || request.auth != null;

      // Admins can write anything.
      allow create, delete: if request.auth != null;

      // Updates: admins can update any field. Public visitors can only
      // bump the `likes` counter by exactly 1 on a published post, and
      // touch no other fields.
      allow update: if request.auth != null
        || (
          resource.data.status == 'published'
          && request.resource.data.likes is number
          && request.resource.data.likes == (resource.data.get('likes', 0) + 1)
          // Every other field must be unchanged.
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        );
    }
    match /admin_users/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /office_hours/{docId} {
      allow read: if true;
      allow update: if true;
      allow create, delete: if request.auth != null;
    }
    match /coupons/{docId} {
      allow read: if true;
      allow update: if true;
      allow create, delete: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
